{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2019",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES5",
      "ES6",
      "ES7",
      "ES2017",
      "ES2019"
    ]
  },
  "include": [
    "**/*.ts"
  ]
}
